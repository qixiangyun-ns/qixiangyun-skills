{
  "profiles": [
    {
      "id": "vat_general",
      "label": "增值税一般纳税人",
      "match_tax_codes": ["BDA0610606"],
      "metrics": [
        {
          "id": "sales_amount",
          "label": "本期销售收入",
          "sum_fields": ["asysljsxse", "ajybfjsxse", "mdtbfckxse", "msxse"],
          "row_filters": {"ewblxh": ["1", "3"]}
        },
        {
          "id": "output_tax_amount",
          "label": "销项税额",
          "sum_fields": ["xxse"],
          "row_filters": {"ewblxh": ["1", "3"]}
        },
        {
          "id": "input_tax_amount",
          "label": "已认证可抵扣进项税",
          "sum_fields": ["jxse"],
          "row_filters": {"ewblxh": ["1", "3"]}
        },
        {
          "id": "input_tax_transfer_out",
          "label": "进项税额转出",
          "sum_fields": ["jxsezc"],
          "row_filters": {"ewblxh": ["1", "3"]}
        },
        {
          "id": "actual_vat_payable",
          "label": "本期实际应缴增值税",
          "sum_fields": ["bqybtse"],
          "row_filters": {"ewblxh": ["1", "3"]}
        },
        {
          "id": "urban_maintenance_tax",
          "label": "城市维护建设税",
          "sum_fields": ["bqybtsecjs"],
          "row_filters": {"ewblxh": ["1"]}
        },
        {
          "id": "education_surcharge",
          "label": "教育费附加",
          "sum_fields": ["bqybtsejyfj"],
          "row_filters": {"ewblxh": ["1"]}
        },
        {
          "id": "local_education_surcharge",
          "label": "地方教育附加",
          "sum_fields": ["bqybtsedfjyfj"],
          "row_filters": {"ewblxh": ["1"]}
        }
      ],
      "derived_metrics": [
        {
          "id": "surcharge_total",
          "label": "附加税费合计",
          "sum_metric_ids": ["urban_maintenance_tax", "education_surcharge", "local_education_surcharge"]
        },
        {
          "id": "total_tax_amount",
          "label": "增值税及附加税合计",
          "sum_metric_ids": ["actual_vat_payable", "surcharge_total"]
        },
        {
          "id": "tax_burden_rate",
          "label": "实际税负率",
          "formula": "percentage",
          "numerator_metric_id": "total_tax_amount",
          "denominator_metric_id": "sales_amount"
        }
      ],
      "patch_map": {
        "sales_amount": "computed.sales_amount",
        "output_tax_amount": "computed.output_tax_amount",
        "input_tax_amount": "computed.input_tax_amount",
        "input_tax_transfer_out": "computed.input_tax_transfer_out",
        "actual_vat_payable": "computed.actual_vat_payable",
        "surcharge_total": "computed.surcharge_total",
        "total_tax_amount": "computed.total_tax_amount",
        "tax_burden_rate": "computed.tax_burden_rate"
      }
    },
    {
      "id": "eit_quarterly",
      "label": "企业所得税",
      "match_tax_codes": ["BDA0611159"],
      "financial_metrics": [
        {
          "id": "operating_revenue",
          "label": "本期经营收入",
          "source": "cbData",
          "sum_keys": ["一、营业收入", "营业收入", "value2:一、营业收入"]
        },
        {
          "id": "operating_cost",
          "label": "本期成本",
          "source": "cbData",
          "sum_keys": ["减：营业成本", "营业成本", "value2:减：营业成本"]
        },
        {
          "id": "profit_total",
          "label": "利润总额",
          "source": "cbData",
          "sum_keys": ["三、利润总额（亏损总额以“-”号填列）", "利润总额", "value2:三、利润总额（亏损总额以“-”号填列）"]
        }
      ],
      "init_metric_keys": {
        "loss_compensation": "mbyqndksLj"
      },
      "patch_map": {
        "profit_total": "computed.profit_total",
        "estimated_income_tax": "computed.estimated_income_tax"
      }
    }
  ]
}
